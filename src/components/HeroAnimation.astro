---
---

<svg
  viewBox="0 0 540 340"
  xmlns="http://www.w3.org/2000/svg"
  class="hero-svg"
  role="img"
  aria-labelledby="hero-svg-title"
>
  <title id="hero-svg-title">Illustration of two smartphones sending messages through curved arcs to a shared code editor, representing Claude Channels</title>

  <!-- Phone 1 (primary, upper-left) -->
  <g id="phone1-group">
    <rect id="phone1-shell" x="30" y="30" width="100" height="180" rx="14" fill="#c0522a" />
    <rect id="phone1-screen" x="38" y="48" width="84" height="140" rx="4" fill="#f5f0e8" />
    <rect id="phone1-line-1" x="48" y="66" width="50" height="6" rx="3" fill="#d5ccbf" />
    <rect id="phone1-line-2" x="48" y="80" width="64" height="6" rx="3" fill="#d5ccbf" />
    <rect id="phone1-line-3" x="48" y="94" width="40" height="6" rx="3" fill="#d5ccbf" />
    <rect id="phone1-indicator" x="64" y="198" width="32" height="4" rx="2" fill="#a8441f" />
  </g>

  <!-- Phone 1 typing dots -->
  <g id="typing1-group">
    <circle id="typing1-dot-1" cx="55" cy="115" r="3.5" fill="#c0522a" opacity="0.7" />
    <circle id="typing1-dot-2" cx="68" cy="115" r="3.5" fill="#c0522a" opacity="0.7" />
    <circle id="typing1-dot-3" cx="81" cy="115" r="3.5" fill="#c0522a" opacity="0.7" />
  </g>

  <!-- Phone 1 sent bubble (pops up briefly) -->
  <g id="sent1-group">
    <rect id="sent1-bg" x="56" y="120" width="56" height="24" rx="6" fill="#c0522a" opacity="0.9" />
    <rect id="sent1-line-1" x="62" y="127" width="36" height="4" rx="2" fill="#f5f0e8" />
    <rect id="sent1-line-2" x="62" y="134" width="24" height="4" rx="2" fill="#f5f0e8" />
  </g>

  <!-- Phone 2 (secondary, smaller, lower-left) -->
  <g id="phone2-group">
    <rect id="phone2-shell" x="55" y="175" width="80" height="144" rx="12" fill="#8a7d6e" />
    <rect id="phone2-screen" x="62" y="190" width="66" height="112" rx="4" fill="#f5f0e8" />
    <rect id="phone2-line-1" x="70" y="205" width="40" height="5" rx="2.5" fill="#d5ccbf" />
    <rect id="phone2-line-2" x="70" y="216" width="50" height="5" rx="2.5" fill="#d5ccbf" />
    <rect id="phone2-line-3" x="70" y="227" width="34" height="5" rx="2.5" fill="#d5ccbf" />
    <rect id="phone2-indicator" x="82" y="310" width="26" height="3" rx="1.5" fill="#6e6358" />
  </g>

  <!-- Phone 2 typing dots -->
  <g id="typing2-group">
    <circle id="typing2-dot-1" cx="76" cy="245" r="3" fill="#8a7d6e" opacity="0.7" />
    <circle id="typing2-dot-2" cx="87" cy="245" r="3" fill="#8a7d6e" opacity="0.7" />
    <circle id="typing2-dot-3" cx="98" cy="245" r="3" fill="#8a7d6e" opacity="0.7" />
  </g>

  <!-- Phone 2 sent bubble -->
  <g id="sent2-group">
    <rect id="sent2-bg" x="70" y="250" width="50" height="22" rx="5" fill="#8a7d6e" opacity="0.9" />
    <rect id="sent2-line-1" x="76" y="256" width="32" height="4" rx="2" fill="#f5f0e8" />
    <rect id="sent2-line-2" x="76" y="263" width="22" height="4" rx="2" fill="#f5f0e8" />
  </g>

  <!-- Arc 1: phone 1 → editor -->
  <path
    id="arc1"
    d="M140 120 Q300 20 385 140"
    fill="none"
    stroke="#c0522a"
    stroke-width="2.5"
    stroke-linecap="round"
  />

  <!-- Arc 2: phone 2 → editor -->
  <path
    id="arc2"
    d="M145 250 Q310 310 385 190"
    fill="none"
    stroke="#8a7d6e"
    stroke-width="2"
    stroke-linecap="round"
  />

  <!-- Travel dots -->
  <circle id="dot1" cx="0" cy="0" r="6" fill="#c0522a" />
  <circle id="dot2" cx="0" cy="0" r="5" fill="#8a7d6e" />

  <!-- Editor group -->
  <g id="editor-group">
    <rect id="editor-frame" x="365" y="60" width="140" height="200" rx="8" fill="#e8e2d6" stroke="#d5ccbf" stroke-width="1.5" />
    <rect id="editor-titlebar" x="365" y="60" width="140" height="24" rx="8" fill="#d5ccbf" />
    <rect x="365" y="76" width="140" height="8" fill="#d5ccbf" />
    <circle id="editor-dot-red" cx="380" cy="72" r="4" fill="#c0522a" />
    <circle id="editor-dot-yellow" cx="392" cy="72" r="4" fill="#dab87a" />
    <circle id="editor-dot-green" cx="404" cy="72" r="4" fill="#7a9e8a" />
    <rect id="code-line-1" x="378" y="96" width="50" height="5" rx="2.5" fill="#7a9e8a" />
    <rect id="code-line-2" x="378" y="108" width="70" height="5" rx="2.5" fill="#7a9e8a" opacity="0.7" />
    <rect id="code-line-3" x="388" y="120" width="55" height="5" rx="2.5" fill="#7a9e8a" opacity="0.5" />
    <rect id="code-line-4" x="388" y="132" width="40" height="5" rx="2.5" fill="#7a9e8a" opacity="0.7" />
    <rect id="code-line-5" x="378" y="144" width="60" height="5" rx="2.5" fill="#7a9e8a" />
    <rect id="code-line-6" x="378" y="156" width="45" height="5" rx="2.5" fill="#7a9e8a" opacity="0.5" />
    <rect id="code-line-7" x="388" y="168" width="50" height="5" rx="2.5" fill="#7a9e8a" opacity="0.7" />
    <rect id="code-line-8" x="378" y="180" width="35" height="5" rx="2.5" fill="#7a9e8a" />
    <rect id="code-line-9" x="378" y="192" width="55" height="5" rx="2.5" fill="#7a9e8a" opacity="0.5" />
    <rect id="code-line-10" x="388" y="204" width="42" height="5" rx="2.5" fill="#7a9e8a" opacity="0.7" />
    <rect id="code-line-11" x="378" y="216" width="60" height="5" rx="2.5" fill="#7a9e8a" />
    <rect id="code-line-12" x="378" y="228" width="38" height="5" rx="2.5" fill="#7a9e8a" opacity="0.7" />
  </g>
</svg>

<style>
  .hero-svg {
    width: 100%;
    max-width: 540px;
  }

  /* Prevent FOUC — hide elements synchronously before JS loads */
  #phone1-group, #phone2-group, #editor-group,
  #arc1, #arc2, #dot1, #dot2,
  #typing1-group, #typing2-group,
  #sent1-group, #sent2-group {
    opacity: 0;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { MotionPathPlugin } from 'gsap/MotionPathPlugin';

  gsap.registerPlugin(MotionPathPlugin);

  function initHeroAnimation() {
    // Respect reduced motion preference
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.set(['#phone1-group', '#phone2-group', '#editor-group', '#arc1', '#arc2'], { opacity: 1 });
      const arc1El = document.querySelector('#arc1') as SVGPathElement | null;
      const arc2El = document.querySelector('#arc2') as SVGPathElement | null;
      if (arc1El) { arc1El.style.strokeDasharray = 'none'; arc1El.style.strokeDashoffset = '0'; }
      if (arc2El) { arc2El.style.strokeDasharray = 'none'; arc2El.style.strokeDashoffset = '0'; }
      return null;
    }

    const ctx = gsap.context(() => {
      // Measure arc lengths
      const arc1El = document.querySelector('#arc1') as SVGPathElement | null;
      const arc2El = document.querySelector('#arc2') as SVGPathElement | null;
      const arc1Len = arc1El ? arc1El.getTotalLength() : 300;
      const arc2Len = arc2El ? arc2El.getTotalLength() : 300;

      // Restore group visibility
      gsap.set(['#phone1-group', '#phone2-group', '#editor-group', '#arc1', '#arc2'], { opacity: 1 });

      // Hide individual children for entrance
      gsap.set([
        '#phone1-shell', '#phone1-screen', '#phone1-line-1', '#phone1-line-2', '#phone1-line-3', '#phone1-indicator',
        '#phone2-shell', '#phone2-screen', '#phone2-line-1', '#phone2-line-2', '#phone2-line-3', '#phone2-indicator',
        '#editor-frame', '#editor-titlebar', '#editor-dot-red', '#editor-dot-yellow', '#editor-dot-green',
        '#code-line-1', '#code-line-2', '#code-line-3', '#code-line-4',
        '#code-line-5', '#code-line-6', '#code-line-7', '#code-line-8',
        '#code-line-9', '#code-line-10', '#code-line-11', '#code-line-12'
      ], { opacity: 0 });

      // Arcs hidden via dash offset
      gsap.set('#arc1', { strokeDasharray: arc1Len, strokeDashoffset: arc1Len });
      gsap.set('#arc2', { strokeDasharray: arc2Len, strokeDashoffset: arc2Len });

      // Transform origins
      gsap.set('#phone1-shell', { transformOrigin: 'center center' });
      gsap.set('#phone2-shell', { transformOrigin: 'center center' });
      gsap.set('#editor-frame', { transformOrigin: 'center center' });
      gsap.set(['#editor-dot-red', '#editor-dot-yellow', '#editor-dot-green'], { transformOrigin: 'center center' });
      gsap.set('#sent1-bg', { transformOrigin: '0% 0%' });
      gsap.set('#sent2-bg', { transformOrigin: '0% 0%' });

      // --- Entrance timeline ---
      const tl = gsap.timeline({ defaults: { overwrite: 'auto' } });

      // Phone 1 entrance
      tl.fromTo('#phone1-shell',
        { x: -30, scale: 0.8, opacity: 0 },
        { x: 0, scale: 1, opacity: 1, duration: 0.5, ease: 'back.out(1.7)' }
      )
      .fromTo('#phone1-screen',
        { opacity: 0 }, { opacity: 1, duration: 0.35, ease: 'power2.out' }, '<0.2'
      )
      .fromTo(['#phone1-line-1', '#phone1-line-2', '#phone1-line-3'],
        { y: 6, opacity: 0 }, { y: 0, opacity: 1, duration: 0.25, ease: 'power2.out', stagger: 0.1 }, '<0.2'
      )
      .fromTo('#phone1-indicator',
        { opacity: 0 }, { opacity: 1, duration: 0.3, ease: 'power2.out' }, '<'
      )

      // Phone 2 entrance (slightly delayed, smaller bounce)
      .fromTo('#phone2-shell',
        { x: -20, scale: 0.75, opacity: 0 },
        { x: 0, scale: 1, opacity: 1, duration: 0.45, ease: 'back.out(1.4)' },
        '-=0.2'
      )
      .fromTo('#phone2-screen',
        { opacity: 0 }, { opacity: 1, duration: 0.3, ease: 'power2.out' }, '<0.15'
      )
      .fromTo(['#phone2-line-1', '#phone2-line-2', '#phone2-line-3'],
        { y: 5, opacity: 0 }, { y: 0, opacity: 1, duration: 0.2, ease: 'power2.out', stagger: 0.08 }, '<0.15'
      )
      .fromTo('#phone2-indicator',
        { opacity: 0 }, { opacity: 1, duration: 0.3, ease: 'power2.out' }, '<'
      )

      // Arcs draw in
      .to('#arc1', { strokeDashoffset: 0, duration: 1.0, ease: 'power1.inOut' }, '-=0.3')
      .to('#arc2', { strokeDashoffset: 0, duration: 1.0, ease: 'power1.inOut' }, '<0.2')

      // Editor entrance
      .fromTo('#editor-frame',
        { x: 30, scale: 0.85, opacity: 0 },
        { x: 0, scale: 1, opacity: 1, duration: 0.5, ease: 'back.out(1.7)' },
        '<0.5'
      )
      .fromTo('#editor-titlebar',
        { opacity: 0 }, { opacity: 1, duration: 0.3, ease: 'power2.out' }, '<0.2'
      )
      .fromTo(['#editor-dot-red', '#editor-dot-yellow', '#editor-dot-green'],
        { scale: 0, opacity: 0 },
        { scale: 1, opacity: 1, duration: 0.25, ease: 'back.out(1.7)', stagger: 0.08 },
        '<0.1'
      )
      .fromTo(
        ['#code-line-1', '#code-line-2', '#code-line-3', '#code-line-4',
         '#code-line-5', '#code-line-6', '#code-line-7', '#code-line-8',
         '#code-line-9', '#code-line-10', '#code-line-11', '#code-line-12'],
        { x: 8, opacity: 0 },
        { x: 0, opacity: 1, duration: 0.2, ease: 'power2.out', stagger: 0.05 },
        '<0.15'
      )
      .addLabel('idle');

      // --- Idle floats ---
      gsap.to('#phone1-group', {
        y: -6, duration: 3.0, ease: 'sine.inOut', repeat: -1, yoyo: true, delay: tl.labels['idle']
      });
      gsap.to('#phone2-group', {
        y: -4, duration: 3.6, ease: 'sine.inOut', repeat: -1, yoyo: true, delay: tl.labels['idle'] + 0.4
      });
      gsap.to('#editor-group', {
        y: 5, duration: 3.4, ease: 'sine.inOut', repeat: -1, yoyo: true, delay: tl.labels['idle'] + 0.6
      });

      // --- Narrative loop: alternating turns ---
      // User 1 edits lines 1-6, User 2 edits lines 7-12
      const user1Lines = ['#code-line-1', '#code-line-2', '#code-line-3', '#code-line-4', '#code-line-5', '#code-line-6'];
      const user2Lines = ['#code-line-7', '#code-line-8', '#code-line-9', '#code-line-10', '#code-line-11', '#code-line-12'];
      const user1Opacities = [1, 0.7, 0.5, 0.7, 1, 0.5];
      const user2Opacities = [0.7, 1, 0.5, 0.7, 1, 0.7];

      const codeStates = [
        // [user1 widths, user2 widths]
        { u1: [50, 70, 55, 40, 60, 45], u2: [50, 35, 55, 42, 60, 38] },
        { u1: [65, 45, 68, 55, 38, 60], u2: [50, 35, 55, 42, 60, 38] },
        { u1: [65, 45, 68, 55, 38, 60], u2: [40, 62, 48, 55, 35, 58] },
        { u1: [40, 75, 50, 65, 55, 35], u2: [40, 62, 48, 55, 35, 58] },
        { u1: [40, 75, 50, 65, 55, 35], u2: [58, 42, 65, 38, 55, 45] },
      ];

      function addUser1Turn(loop: gsap.core.Timeline, stateIdx: number) {
        const widths = codeStates[stateIdx].u1;

        // Typing dots on phone 1
        loop.set('#typing1-group', { opacity: 1 })
          .fromTo(['#typing1-dot-1', '#typing1-dot-2', '#typing1-dot-3'],
            { y: 0 }, { y: -5, duration: 0.28, ease: 'sine.out', yoyo: true, repeat: 3, stagger: 0.12 }
          )
          .to('#typing1-group', { opacity: 0, duration: 0.15 });

        // Sent bubble pops up near phone 1
        loop.set('#sent1-group', { opacity: 1 })
          .fromTo('#sent1-bg', { scale: 0, opacity: 0 }, { scale: 1, opacity: 0.9, duration: 0.25, ease: 'back.out(1.7)' })
          .fromTo(['#sent1-line-1', '#sent1-line-2'], { opacity: 0 }, { opacity: 1, duration: 0.15, stagger: 0.06 })
          .to('#sent1-group', { opacity: 0, duration: 0.3, delay: 0.2 });

        // Dot travels along arc 1
        loop.set('#dot1', { opacity: 1 })
          .to('#dot1', {
            motionPath: { path: '#arc1', align: '#arc1', alignOrigin: [0.5, 0.5], autoRotate: false, start: 0, end: 1 },
            duration: 1.2, ease: 'power2.inOut'
          }, '<0.1')
          .set('#dot1', { opacity: 0 });

        // Code lines 1-6 update
        loop.to(user1Lines, { opacity: 0.1, duration: 0.25, stagger: 0.03 });
        user1Lines.forEach((id, i) => {
          loop.to(id, {
            attr: { width: widths[i] }, opacity: user1Opacities[i],
            duration: 0.18, ease: 'power2.out'
          }, i === 0 ? '>' : '>-0.1');
        });
        loop.to({}, { duration: 0.6 });
      }

      function addUser2Turn(loop: gsap.core.Timeline, stateIdx: number) {
        const widths = codeStates[stateIdx].u2;

        // Typing dots on phone 2
        loop.set('#typing2-group', { opacity: 1 })
          .fromTo(['#typing2-dot-1', '#typing2-dot-2', '#typing2-dot-3'],
            { y: 0 }, { y: -4, duration: 0.26, ease: 'sine.out', yoyo: true, repeat: 3, stagger: 0.12 }
          )
          .to('#typing2-group', { opacity: 0, duration: 0.15 });

        // Sent bubble pops up near phone 2
        loop.set('#sent2-group', { opacity: 1 })
          .fromTo('#sent2-bg', { scale: 0, opacity: 0 }, { scale: 1, opacity: 0.9, duration: 0.25, ease: 'back.out(1.7)' })
          .fromTo(['#sent2-line-1', '#sent2-line-2'], { opacity: 0 }, { opacity: 1, duration: 0.15, stagger: 0.06 })
          .to('#sent2-group', { opacity: 0, duration: 0.3, delay: 0.2 });

        // Dot travels along arc 2
        loop.set('#dot2', { opacity: 1 })
          .to('#dot2', {
            motionPath: { path: '#arc2', align: '#arc2', alignOrigin: [0.5, 0.5], autoRotate: false, start: 0, end: 1 },
            duration: 1.2, ease: 'power2.inOut'
          }, '<0.1')
          .set('#dot2', { opacity: 0 });

        // Code lines 7-12 update
        loop.to(user2Lines, { opacity: 0.1, duration: 0.25, stagger: 0.03 });
        user2Lines.forEach((id, i) => {
          loop.to(id, {
            attr: { width: widths[i] }, opacity: user2Opacities[i],
            duration: 0.18, ease: 'power2.out'
          }, i === 0 ? '>' : '>-0.1');
        });
        loop.to({}, { duration: 0.6 });
      }

      // Build the alternating loop: User1, User2, User1, User2, ...
      const loop = gsap.timeline({ repeat: -1, delay: tl.labels['idle'] + 0.8 });
      addUser1Turn(loop, 1);
      addUser2Turn(loop, 2);
      addUser1Turn(loop, 3);
      addUser2Turn(loop, 4);
      // State 0 is the initial — loop restart resets visually
    });

    return ctx;
  }

  // Astro lifecycle hooks for View Transitions compatibility
  let heroCtx: gsap.Context | null = null;

  document.addEventListener('astro:after-swap', () => {
    heroCtx?.revert();
    heroCtx = null;
  });

  document.addEventListener('astro:page-load', () => {
    heroCtx = initHeroAnimation();
  });

  heroCtx = initHeroAnimation();
</script>
