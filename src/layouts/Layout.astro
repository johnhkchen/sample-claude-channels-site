---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
</head>
<body>
  <slot />

  <footer>
    <p>Built by <a href="https://b28.dev" target="_blank" rel="noopener" class="footer-link">b28.dev</a></p>
    <p class="footer-blurb">Every change on this site was made by chatting with Claude on Discord — no manual coding.</p>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

